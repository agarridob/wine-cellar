#: wine_cellar/apps/wine/forms.py:226
msgid "Enter the name of the wine as indicated on the label."
msgstr "Introduce el nombre del vino tal como aparece en la etiqueta."

#: wine_cellar/apps/wine/forms.py:231
msgid "Select the type of wine from the dropdown."
msgstr "Selecciona el tipo de vino en el desplegable."

#: wine_cellar/apps/wine/forms.py:234
#| msgid "Sweet"
msgid "Sweetness"
msgstr "Dulzor"

#: wine_cellar/apps/wine/forms.py:238
msgid "Select the sweetness level of the wine."
msgstr "Selecciona el nivel de dulzor del vino."

#: wine_cellar/apps/wine/forms.py:246
msgid "Select the country the wine was produced in as indicated on the label."
msgstr ""
"Selecciona el país donde se produjo el vino, tal como aparece en la "
"etiqueta."

#: wine_cellar/apps/wine/forms.py:253
#| msgid "Enter the names of the vineyards which produced the wine."
msgid "Enter the name of the region the wine is from."
msgstr "Introduce el nombre de la región de origen del vino."

#: wine_cellar/apps/wine/forms.py:259
#| msgid "Enter the names of the vineyards which produced the wine."
msgid "Enter the name of the appellation of the wine."
msgstr "Introduce el nombre de la denominación de origen del vino."

#: wine_cellar/apps/wine/forms.py:265
msgid ""
"Select the location (region, vineyard, site) the wine is from. Click inside "
"the map to set a marker. The marker can be dragged when pressed."
msgstr ""
"Selecciona la ubicación (región, viñedo, parcela) de origen del vino. Haz "
"clic dentro del mapa para colocar un marcador. El marcador se puede "
"arrastrar manteniéndolo pulsado."

#: wine_cellar/apps/wine/forms.py:274 wine_cellar/apps/wine/models.py:53
#: wine_cellar/apps/wine/templates/wine_detail.html:127
msgid "Size"
msgstr "Tamaño"

#: wine_cellar/apps/wine/forms.py:276
msgid "Please enter the volume of bottle or box ect. in liters, e.g. 0.75."
msgstr ""
"Introduce el volumen de la botella o caja, etc., en litros, p. ej. 0,75."

#: wine_cellar/apps/wine/forms.py:286
msgid ""
"Please enter the percentage of alcohol in the wine. This information is "
"typically found on the label and indicates the strength of the wine."
msgstr ""
"Introduce el porcentaje de alcohol del vino. Esta información suele aparecer"
" en la etiqueta e indica la graduación del vino."

#: wine_cellar/apps/wine/forms.py:307
msgid ""
"Enter the year the grapes were harvested to produce the wine. Typically, "
"vintage years are prominently displayed on wine labels."
msgstr ""
"Introduce el año en que se vendimiaron las uvas para elaborar el vino. "
"Normalmente, la añada aparece de forma destacada en las etiquetas."

#: wine_cellar/apps/wine/forms.py:316
msgid ""
"Select or add the grape varieties used to produce the wine. You can select "
"multiple options if applicable."
msgstr ""
"Selecciona o añade las variedades de uva empleadas para elaborar el vino. "
"Puedes seleccionar varias opciones si procede."

#: wine_cellar/apps/wine/forms.py:325
msgid ""
"Add any attributes that apply to this wine, such as natural, retsina or "
"organic."
msgstr ""
"Añade cualquier atributo que se aplique a este vino, como natural, retsina o"
" ecológico."

#: wine_cellar/apps/wine/forms.py:331
msgid "Select the date this wine should be drunk by."
msgstr "Selecciona la fecha límite para beber este vino."

#: wine_cellar/apps/wine/forms.py:340
msgid ""
"Enter dishes, cuisines, or ingredients that complement the flavors of this "
"wine."
msgstr ""
"Introduce platos, cocinas o ingredientes que complementen los sabores de "
"este vino."

#: wine_cellar/apps/wine/forms.py:349
msgid "Enter the names of the vineyards which produced the wine."
msgstr "Introduce los nombres de los viñedos que produjeron el vino."

#: wine_cellar/apps/wine/forms.py:355
msgid "Where did you get the wine from?"
msgstr "¿De dónde obtuviste el vino?"

#: wine_cellar/apps/wine/forms.py:375
#| msgid "Enter the name of the wine as indicated on the label."
msgid ""
"Enter the barcode number of the wine as indicated on the label or scan using"
" the button below."
msgstr ""
"Introduce el número del código de barras del vino tal como aparece en la "
"etiqueta o escanéalo con el botón de abajo."

#: wine_cellar/apps/wine/forms.py:384
msgid ""
"Share your thoughts, tasting experiences, or any anecdotes related to this "
"wine."
msgstr ""
"Comparte tus impresiones, experiencias de cata o cualquier anécdota "
"relacionada con este vino."

#: wine_cellar/apps/wine/forms.py:391
msgid "Rate this wine on a scale from 0 to 10."
msgstr "Puntúa este vino en una escala del 0 al 10."

#: wine_cellar/apps/wine/forms.py:396
msgid "Upload a photo of the front of the wine bottle."
msgstr "Sube una foto de la parte delantera de la botella."

#: wine_cellar/apps/wine/forms.py:401
msgid "Upload a photo of the back of the wine bottle."
msgstr "Sube una foto de la parte trasera de la botella."

#: wine_cellar/apps/wine/forms.py:406
msgid "Upload a photo of the front of the bottle label."
msgstr "Sube una foto de la etiqueta delantera de la botella."

#: wine_cellar/apps/wine/forms.py:411
msgid "Upload a photo of the back of the bottle label."
msgstr "Sube una foto de la etiqueta trasera de la botella."

#: wine_cellar/apps/wine/forms.py:448
#| msgid "Upload a photo of the front of the bottle label."
msgid "Upload an image of the front label."
msgstr "Sube una imagen de la etiqueta delantera."

#: wine_cellar/apps/wine/forms.py:453
msgid ""
"Upload an image of the back label (optional, adds tasting notes and food "
"pairings)."
msgstr ""
"Sube una imagen de la etiqueta trasera (opcional, añade notas de cata y "
"maridajes)."

