(app) {
	tls {
		dns cloudflare {env.CF_DNS_API_TOKEN}
	}

	@files {
		path /static/* /media/*
	}
	handle @files {
		file_server
	}

	handle {
		@health path /health
		respond @health "Not Found" 404
		reverse_proxy web:8000
	}
}

cellar.ha-hinojal.com {
	import app
}

bodega.hinojal.app {
	import app
}
